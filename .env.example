OPENROUTER_API_KEY=

# Required Kafka event stream. `pnpm infra:up` exposes the local broker here.
# Production should use managed brokers with TLS/SASL and replication >= 3.
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=murmur-web
KAFKA_SWARM_EVENTS_TOPIC=murmur.swarm.events
KAFKA_SSL=0
KAFKA_SASL_MECHANISM=plain
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_CONNECTION_TIMEOUT_MS=5000
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_RETRY_COUNT=8
KAFKA_LOG_LEVEL=error

# Required Redis state. Use rediss:// for TLS-enabled managed Redis in production.
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=3000
MURMUR_RUNS_PER_WINDOW=20
MURMUR_RUN_WINDOW_SECONDS=3600
MURMUR_MODEL_CALLS_PER_WINDOW=120
MURMUR_MODEL_WINDOW_SECONDS=3600
MURMUR_RUN_SESSION_TTL_SECONDS=86400
MURMUR_RUN_EVENT_STREAM_MAX_LENGTH=10000
MURMUR_INFRA_HEALTH_CACHE_MS=5000
